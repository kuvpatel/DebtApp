{
  "openapi": "3.1.1",
  "info": {
    "title": "DebtApi | v1",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://localhost:7111"
    },
    {
      "url": "http://localhost:5127"
    }
  ],
  "paths": {
    "/api/Debt": {
      "post": {
        "tags": [
          "Debt"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RepaymentPlanRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/RepaymentPlanRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/RepaymentPlanRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Debt/customerid": {
      "get": {
        "tags": [
          "Debt"
        ],
        "parameters": [
          {
            "name": "customerId",
            "in": "query",
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Debt/id": {
      "get": {
        "tags": [
          "Debt"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "RepaymentPlanRequest": {
        "type": "object",
        "properties": {
          "id": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "debtId": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "monthlyPaymentAmount": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "dateStarted": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Debt"
    }
  ]
}